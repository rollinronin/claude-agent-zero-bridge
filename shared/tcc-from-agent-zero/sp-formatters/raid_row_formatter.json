{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/row-formatting.schema.json",
  "hideColumnHeader": true,
  "hideSelection": false,
  "rowFormatter": {
    "elmType": "div",
    "style": {
      "display": "flex",
      "flex-direction": "row",
      "align-items": "stretch",
      "background-color": "#ffffff",
      "border-radius": "8px",
      "box-shadow": "0 2px 8px rgba(0,0,0,0.10)",
      "margin": "5px 0px",
      "overflow": "hidden",
      "border": "1px solid #e8edf4",
      "min-height": "80px",
      "font-family": "Segoe UI, sans-serif"
    },
    "children": [
      {
        "elmType": "div",
        "style": {
          "width": "6px",
          "flex-shrink": "0",
          "background-color": "=if([$RAG]=='Red','#cc2222',if([$RAG]=='Amber','#c97000','#157a3c'))"
        }
      },
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "flex-direction": "column",
          "padding": "12px 16px",
          "flex": "1",
          "gap": "5px"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "justify-content": "space-between",
              "align-items": "center",
              "gap": "8px"
            },
            "children": [
              {
                "elmType": "div",
                "style": { "display": "flex", "align-items": "center", "gap": "8px", "flex": "1" },
                "children": [
                  {
                    "elmType": "svg",
                    "style": { "width": "12px", "height": "12px", "flex-shrink": "0" },
                    "attributes": { "viewBox": "0 0 12 12" },
                    "children": [{
                      "elmType": "circle",
                      "attributes": {
                        "cx": "6", "cy": "6", "r": "5",
                        "fill": "=if([$RAG]=='Red','#cc2222',if([$RAG]=='Amber','#c97000','#157a3c'))"
                      }
                    }]
                  },
                  {
                    "elmType": "span",
                    "style": { "font-size": "13px", "font-weight": "600", "color": "#1a1a1a" },
                    "txtContent": "[$Title]"
                  }
                ]
              },
              {
                "elmType": "div",
                "style": { "display": "flex", "gap": "6px", "align-items": "center", "flex-shrink": "0" },
                "children": [
                  {
                    "elmType": "span",
                    "style": {
                      "font-size": "10px", "font-weight": "700",
                      "padding": "2px 8px", "border-radius": "20px",
                      "background-color": "=if([$RAIDType]=='Risk','#fde8e8',if([$RAIDType]=='Issue','#fff8ec',if([$RAIDType]=='Decision','#e0f0ff','#e8f5e9')))",
                      "color": "=if([$RAIDType]=='Risk','#b91c1c',if([$RAIDType]=='Issue','#92400e',if([$RAIDType]=='Decision','#1e40af','#166534')))",
                      "text-transform": "uppercase", "letter-spacing": "0.04em"
                    },
                    "txtContent": "[$RAIDType]"
                  },
                  {
                    "elmType": "span",
                    "style": {
                      "font-size": "10px", "font-weight": "600",
                      "padding": "2px 8px", "border-radius": "20px",
                      "background-color": "=if([$Status]=='Closed','#f0f0f0',if([$Status]=='In Progress','#e8f4fb','#fff0f0'))",
                      "color": "=if([$Status]=='Closed','#767676',if([$Status]=='In Progress','#0554a4','#cc2222'))"
                    },
                    "txtContent": "[$Status]"
                  }
                ]
              }
            ]
          },
          {
            "elmType": "span",
            "style": {
              "font-size": "12px", "color": "#555555",
              "overflow": "hidden", "white-space": "nowrap", "text-overflow": "ellipsis"
            },
            "txtContent": "[$Description]"
          },
          {
            "elmType": "div",
            "style": { "display": "flex", "gap": "20px", "margin-top": "2px", "align-items": "center" },
            "children": [
              {
                "elmType": "span",
                "style": {
                  "font-size": "10px", "font-weight": "700", "padding": "1px 7px",
                  "border-radius": "4px", "border": "1px solid #d0dff0",
                  "color": "#0554a4", "background-color": "#eaf2fb"
                },
                "txtContent": "[$Project]"
              },
              {
                "elmType": "span",
                "style": { "font-size": "11px", "color": "#767676" },
                "txtContent": "='Owner: ' + [$Owner]"
              },
              {
                "elmType": "span",
                "style": { "font-size": "11px", "color": "#767676" },
                "txtContent": "='Due: ' + toString([$Due_x0020_Date])"
              }
            ]
          }
        ]
      }
    ]
  }
}
