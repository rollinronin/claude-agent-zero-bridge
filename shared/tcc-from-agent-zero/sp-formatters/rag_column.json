{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/column-formatting.schema.json",
  "elmType": "div",
  "style": { "display": "flex", "align-items": "center", "gap": "7px" },
  "children": [
    {
      "elmType": "svg",
      "style": { "width": "12px", "height": "12px", "flex-shrink": "0" },
      "attributes": { "viewBox": "0 0 12 12" },
      "children": [{
        "elmType": "circle",
        "attributes": {
          "cx": "6", "cy": "6", "r": "5",
          "fill": "=if([$RAG]=='Red','#cc2222',if([$RAG]=='Amber','#c97000','#157a3c'))"
        }
      }]
    },
    {
      "elmType": "span",
      "style": {
        "font-size": "11px", "font-weight": "600",
        "color": "=if([$RAG]=='Red','#b91c1c',if([$RAG]=='Amber','#92400e','#166534'))"
      },
      "txtContent": "[$RAG]"
    }
  ]
}
